# 複製為 .env 並填入實際值：cp .env.example .env
# 註解請用 #（不要用 ;，python-dotenv 無法解析）

# ── LLM Provider API Keys ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MONICA_API_KEY=
MONICA_BASE_URL=http://localhost:8001/v1

# claude | openai | gemini | monica | deepseek（大小寫不敏感）
DEFAULT_PROVIDER=claude

# ── 資料庫 ────────────────────────────────────────────────────────────
DB_PATH=../data/learning.db
# Windows + Docker bind-mount 必須用 DELETE；WAL 常導致 disk I/O error
SQLITE_JOURNAL_MODE=DELETE

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRE_DAYS=7

# ── Curriculum Pipeline ───────────────────────────────────────────────
# stage 標題去重合併閾值（0~1）；高=只合併幾乎一樣的，低=積極合併
# 預設 0.85；EPUB 多章節若誤合可調高（0.90+），主題重複嚴重可調低（0.75）
STAGE_TITLE_MERGE_THRESHOLD=0.85
# 跨 source 用 key_concepts jaccard 合併閾值（0~1）；
# 預設 0.6 — per-source split 結果中，key_concepts 重疊 ≥ 60% 視為同主題合併
STAGE_CONCEPT_OVERLAP_THRESHOLD=0.6
# Splitter 觸發 reroll 的最少 missing 數；預設 2（missing ≤ 1 直接 soft-pass 省一輪 LLM）
SPLITTER_VERIFIER_MIN_MISSES=2
# 1= 多檔合併後跑 ConceptCanonicalize 統一關鍵詞命名（耗一次 LLM）
CONCEPT_CANONICALIZE=0
# hard= verifier 失敗中止；soft= 放行並寫 quality_warnings
# SPLITTER_FAIL_MODE=hard

# ── Arq 背景 Worker（CURRICULUM_USE_ARQ=1 時必開 Redis + worker）──────
CURRICULUM_USE_ARQ=0
# 本機 docker compose 用 6380；容器內 worker 用 redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
# ARQ_MAX_JOBS=1
# ARQ_JOB_TIMEOUT_S=7200

# ── LLM Result Cache（curriculum agents）──────────────────────────────
# LLM_CACHE_ENABLED=0
# CURRICULUM_PROMPT_VERSION=1
# LLM_CACHE_EVICT_DAYS=90

# ── LLM 全域併發（多使用者 / worker 共用 Monica 時建議開）────────────
# 0= 關閉限流；API 與 docker worker 需相同值 + 相同 REDIS_URL
LLM_MAX_CONCURRENT=0
LLM_SLOT_WAIT_TIMEOUT_S=120
LLM_SLOT_LEASE_S=600

# ── 上傳 / CORS（可選）──────────────────────────────────────────────
# UPLOAD_ORPHAN_MAX_AGE_HOURS=24
# UPLOAD_MAX_CHAR_COUNT=500000
# 單一上傳檔案大小上限（MB）；預設 10，超過回 413
# UPLOAD_MAX_FILE_MB=10
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGIN_REGEX=https://.*\.trycloudflare\.com

# ── 測試用（一般開發不必設）──────────────────────────────────────────
# RUN_LLM_TESTS=1
