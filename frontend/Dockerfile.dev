# 前端開發容器：vite dev server（HMR）。
# 對應 docker-compose.yml 的 frontend 服務；正式部署請另用多階段 build + nginx。
FROM node:22-alpine

WORKDIR /app

# 先複製 lockfile 安裝依賴，利用 layer cache。
# 用 npm install 而非 npm ci：repo 的 package-lock.json 在 Windows 產生，
# 缺少 Linux 平台的 optional deps（@emnapi/* 等），npm ci 會因 lockfile 不同步而失敗。
COPY package.json package-lock.json ./
RUN npm install

# 其餘原始碼在 compose 以 bind mount 覆蓋；此處 COPY 讓不掛 volume 時也能跑。
COPY . .

EXPOSE 5173

# --host 0.0.0.0：讓容器外（host 的 localhost:5173）可連入。
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
